# Google Sheets Configuration
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Email Configuration (SMTP - works with any email provider)
EMAIL_USER=your_work_email@company.com
EMAIL_PASSWORD=your_email_password_or_app_key
SMTP_SERVER=smtp.your-email-provider.com
SMTP_PORT=587

# Optional: API Keys for email discovery (free tiers available)
# HUNTER_API_KEY=your_hunter_api_key
# CLEARBIT_API_KEY=your_clearbit_api_key

# Outreach Settings
DAILY_EMAIL_LIMIT=50
EMAIL_TEMPLATE_PATH=./templates/outreach_template.txt

# Sender Information (for email templates)
SENDER_NAME=Your Name
SENDER_TITLE=Your Job Title
SENDER_COMPANY=Your Company
SENDER_PHONE=Your Phone Number

# Scraping Settings
REQUEST_TIMEOUT=10
MAX_RETRIES=3
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36
